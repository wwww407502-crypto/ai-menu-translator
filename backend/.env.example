PORT=3000
# 阿里云百炼 API Key
OPENAI_API_KEY=REPLACE_WITH_YOUR_DASHSCOPE_API_KEY
# 阿里云 OpenAI 兼容接口地址
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 当前调用模型
VISION_MODEL=qwen3-vl-flash
# 第二阶段结构化解析默认开启推理
PARSE_ENABLE_THINKING=true
# 可选：限制思考 token，0 表示不额外限制
PARSE_THINKING_BUDGET=0
# OCR 专用模型
OCR_MODEL=qwen-vl-ocr-2025-11-20
# 请求体 JSON 限制
REQUEST_JSON_LIMIT=1mb
# 上传图片大小限制（字节）
MAX_UPLOAD_BYTES=5242880
# 汇率服务超时（毫秒）
EXCHANGE_RATE_TIMEOUT_MS=5000
# OCR 请求超时（毫秒）
OCR_TIMEOUT_MS=20000
# 结构化解析请求超时（毫秒）
PARSE_TIMEOUT_MS=30000
# 允许的目标语言，逗号分隔
ALLOWED_TARGET_LANGUAGES=zh-CN,zh-TW,en,ja,ko
# CORS 白名单，逗号分隔；无 Origin 的原生客户端请求不受影响
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
# 可选 API Key，逗号分隔；配置后 `/api/v1/*` 需要携带 `x-api-key`
API_KEYS=
# 反向代理环境可开启
TRUST_PROXY=false
# Node HTTP 服务级超时配置（毫秒）
REQUEST_TIMEOUT_MS=35000
HEADER_TIMEOUT_MS=36000
KEEP_ALIVE_TIMEOUT_MS=5000
# 并发与限流配置
MAX_CONCURRENT_PARSES=4
GENERAL_RATE_LIMIT_WINDOW_MS=60000
GENERAL_RATE_LIMIT_MAX_REQUESTS=120
PARSE_RATE_LIMIT_WINDOW_MS=60000
PARSE_RATE_LIMIT_MAX_REQUESTS=10
