PORT=3000
# 阿里云百炼 API Key
DASHSCOPE_API_KEY=REPLACE_WITH_YOUR_DASHSCOPE_API_KEY
# 阿里云 OpenAI 兼容接口地址，可选覆盖
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 当前调用模型
VISION_MODEL=qwen3.5-plus
# 模型 SDK 超时不自动重试，避免一次小程序请求被隐藏重试拖到超时
MODEL_MAX_RETRIES=0
# 连接类错误时额外重试次数；会重建一次 SDK 客户端
MODEL_CONNECTION_RETRY_COUNT=1
# 模型最大输出 token，防止大菜单无限输出
MODEL_MAX_TOKENS=4096
# 视觉模型直解析超时（毫秒）
DIRECT_PARSE_TIMEOUT_MS=90000
# 是否开启模型推理能力；关闭可减少菜单价格误判
PARSE_ENABLE_THINKING=false
# 最大思考 token；关闭时保持 0
PARSE_THINKING_BUDGET=0
# 请求体 JSON 限制
REQUEST_JSON_LIMIT=1mb
# 上传图片大小限制（字节）
MAX_UPLOAD_BYTES=5242880
# 汇率服务超时（毫秒）
EXCHANGE_RATE_TIMEOUT_MS=5000
# 菜单解析请求超时（毫秒）
PARSE_TIMEOUT_MS=90000
# 允许的目标语言，逗号分隔
ALLOWED_TARGET_LANGUAGES=zh-CN,zh-TW,en,ja,ko
# CORS 白名单，逗号分隔；无 Origin 的原生客户端请求不受影响
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
# 可选 API Key，逗号分隔；配置后 `/api/v1/*` 需要携带 `x-api-key`
API_KEYS=
# 反向代理环境可开启（设为 true）
TRUST_PROXY=
# Node HTTP 服务级超时配置（毫秒）
# 代码会自动确保该值不低于完整解析链路耗时，这里给出清晰的生产默认值
REQUEST_TIMEOUT_MS=230000
HEADER_TIMEOUT_MS=231000
KEEP_ALIVE_TIMEOUT_MS=5000
# 并发与限流配置
MAX_CONCURRENT_PARSES=4
GENERAL_RATE_LIMIT_WINDOW_MS=60000
GENERAL_RATE_LIMIT_MAX_REQUESTS=120
PARSE_RATE_LIMIT_WINDOW_MS=60000
PARSE_RATE_LIMIT_MAX_REQUESTS=10
MAX_MULTI_UPLOAD_FILES=5
