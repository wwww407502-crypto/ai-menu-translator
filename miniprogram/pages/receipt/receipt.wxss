.receipt-page {
  min-height: 100vh;
  padding: 28rpx 30rpx calc(176rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(244, 246, 255, 0.92) 0%, rgba(255, 255, 255, 0.98) 24%, #ffffff 100%);
  color: #1e2240;
}

.receipt-shell {
  max-width: 680rpx;
  margin: 0 auto;
}

.hero {
  margin-top: 118rpx;
  text-align: center;
}

.hero__title {
  display: block;
  font-size: 56rpx;
  font-weight: 500;
  line-height: 1.28;
  color: #252b4d;
}

.hero-divider {
  display: flex;
  align-items: center;
  margin: 66rpx 30rpx 18rpx;
}

.hero-divider__line {
  flex: 1;
  height: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(114, 128, 255, 0.16) 0%, rgba(114, 128, 255, 0.24) 100%);
}

.hero-divider__cap {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #39407f;
}

.hero-divider__cap--left {
  margin-right: -6rpx;
}

.hero-divider__cap--right {
  margin-left: -6rpx;
}

.hero__hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  letter-spacing: 2rpx;
  color: rgba(101, 108, 146, 0.56);
}

.order-card {
  margin-top: 28rpx;
  padding: 18rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 248, 255, 0.92) 100%);
  box-shadow: 0 18rpx 48rpx rgba(45, 54, 112, 0.08);
}

.order-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx 0;
}

.order-row + .order-row {
  border-top: 1rpx solid rgba(56, 65, 114, 0.08);
}

.order-row__names {
  flex: 1;
  min-width: 0;
}

.order-row__title {
  display: block;
  font-size: 38rpx;
  font-weight: 500;
  line-height: 1.32;
  color: #252b4d;
}

.order-row__summary {
  display: block;
  margin-top: 12rpx;
  font-size: 27rpx;
  font-weight: 500;
  line-height: 1.5;
  color: rgba(37, 43, 77, 0.78);
}

.order-row__subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(86, 92, 129, 0.54);
}

.order-row__detail {
  display: block;
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: rgba(67, 74, 121, 0.7);
}

.order-row__detail--strong {
  color: rgba(37, 43, 77, 0.82);
}

.gratitude {
  margin-top: 92rpx;
  text-align: center;
}

.gratitude__title {
  display: block;
  font-size: 50rpx;
  font-weight: 500;
  line-height: 1.32;
  color: #252b4d;
}

.detail-card {
  margin-top: 96rpx;
  padding: 24rpx 24rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(245, 247, 252, 0.56);
  box-shadow: inset 0 0 0 1rpx rgba(91, 102, 165, 0.04);
}

.detail-card__head,
.detail-card__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-card__titles {
  flex: 1;
  min-width: 0;
}

.detail-card__label,
.detail-card__action,
.detail-card__meta,
.detail-card__hint,
.detail-card__total-label {
  font-size: 22rpx;
  color: rgba(86, 92, 129, 0.52);
}

.detail-card__hint {
  display: block;
  margin-top: 6rpx;
  line-height: 1.5;
}

.detail-card__action {
  color: rgba(37, 43, 77, 0.78);
}

.detail-card__order-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 18rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.62);
}

.detail-card__order-line {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(37, 43, 77, 0.86);
}

.detail-card__meta {
  margin-top: 18rpx;
}

.detail-card__totals {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.detail-card__total-block {
  flex: 1;
  min-width: 0;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.62);
}

.detail-card__total-block--secondary {
  background: rgba(247, 248, 255, 0.82);
}

.detail-card__total-value {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(37, 43, 77, 0.88);
}

.bottom-dock {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
}

.bottom-dock__summary {
  display: flex;
  align-items: center;
}

.bottom-dock__count {
  font-size: 40rpx;
  font-weight: 500;
  line-height: 1.2;
  color: #252b4d;
}

.bottom-dock__action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-width: 204rpx;
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #10162f;
  box-shadow: 0 16rpx 34rpx rgba(16, 22, 47, 0.2);
}

.bottom-dock__action-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ffffff;
}

.bottom-dock__action-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}
