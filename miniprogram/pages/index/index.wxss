.home {
  position: relative;
  overflow: hidden;
  padding: 72rpx 32rpx 40rpx;
  background: #f2f2f7;
}

.home__glow {
  display: none;
}

.home__glow--one {
  top: 0;
}

.home__glow--two {
  left: 0;
}

.home__content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: calc(100vh - 112rpx);
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 56rpx;
}

.hero__title {
  font-size: 72rpx;
  line-height: 1.02;
  font-weight: 700;
  color: #111111;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.primary-action,
.secondary-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 120rpx;
  padding: 0 32rpx;
  border-radius: 28rpx;
  text-align: center;
}

.primary-action {
  color: #ffffff;
  background: #007aff;
}

.secondary-action {
  color: #007aff;
  background: #f5f5f7;
}

.action-title {
  font-size: 30rpx;
  font-weight: 700;
}

.notice {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-top: 28rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #fff7ed;
}

.notice__label {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: #b26a00;
}

.notice__text {
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a4b00;
}

.processing {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: calc(100vh - 112rpx);
  padding: 0 48rpx;
  text-align: center;
  background: #f2f2f7;
}

.processing__ring {
  width: 132rpx;
  height: 132rpx;
  border: 6rpx solid #d1d1d6;
  border-top-color: #007aff;
  border-radius: 50%;
}

.processing__eyebrow {
  margin-top: 40rpx;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #8e8e93;
}

.processing__title {
  margin-top: 18rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #111111;
}

.processing__desc {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6e6e73;
}

.tertiary-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 100rpx;
  padding: 16rpx 32rpx;
  border-radius: 28rpx;
  text-align: center;
  color: #8e8e93;
  background: transparent;
  border: 2rpx solid #d1d1d6;
}

.action-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8e8e93;
}

.multi-select {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  min-height: calc(100vh - 112rpx);
  padding: 32rpx;
}

.multi-select__header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.multi-select__title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111111;
}

.multi-select__hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

.multi-select__list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  flex: 1;
}

.multi-select__item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.multi-select__thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.multi-select__label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.multi-select__remove {
  font-size: 24rpx;
  color: #ff3b30;
  background: transparent;
  padding: 8rpx 20rpx;
  border: 2rpx solid #ff3b30;
  border-radius: 12rpx;
}

.multi-select__actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}
